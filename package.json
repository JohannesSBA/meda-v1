{
  "name": "meda",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:concurrency": "vitest run --config vitest.integration.config.ts __tests__/integration/payments.concurrency.test.ts",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "issues:import": "node scripts/import-github-issues.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.993.0",
    "@neondatabase/auth": "^0.2.0-beta.1",
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "@rehookify/datepicker": "^6.6.8",
    "@supabase/supabase-js": "^2.97.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.4",
    "axios": "^1.13.5",
    "chapa-nodejs": "^2.1.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "html5-qrcode": "^2.3.8",
    "mapbox-gl": "^3.18.1",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-icons": "^5.5.0",
    "resend": "^6.9.2",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.16.5",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.33",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "tailwindcss": "^4",
    "testcontainers": "^11.12.0",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wrangler": "^4.67.0"
  }
}
