// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Prisma Schema for Event Manager Database
// This schema matches the existing PostgreSQL database structure defined in db/init/02_event_manager_db_schema.sql

// Enums
enum AttendeeStatus {
  RSVPed
  Maybe
  NotGoing

  @@map("attendee_status")
}

enum InvitationStatus {
  Active
  Expired
  Revoked

  @@map("invitation_status")
}

enum PaymentStatus {
  created
  processing
  succeeded
  failed
  canceled
  requires_refund

  @@map("payment_status")
}

enum PaymentProvider {
  balance
  chapa

  @@map("payment_provider")
}

enum OwnerSubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIAL
}

enum SlotStatus {
  OPEN
  RESERVED
  BOOKED
  BLOCKED
  CANCELLED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  EXPIRED
  CANCELLED
  COMPLETED
}

enum ProductType {
  DAILY
  MONTHLY
}

enum PartyStatus {
  FORMING
  PENDING_PAYMENT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PartyMemberStatus {
  INVITED
  JOINED
  PAID
  EXPIRED
  REMOVED
}

enum PaymentPoolStatus {
  PENDING
  FULFILLED
  EXPIRED
  CANCELLED
}

enum ContributionStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
  REFUNDED
}

enum TicketStatus {
  PURCHASED
  ASSIGNMENT_PENDING
  ASSIGNED
  VALID
  CHECKED_IN
  EXPIRED
  CANCELLED
}

enum PayoutStatus {
  PENDING
  PROCESSING
  PAID
  FAILED
  CANCELED
}

model Category {
  categoryId   String  @id @default(uuid()) @map("category_id") @db.Uuid
  categoryName String  @map("category_name") @db.VarChar(50)
  description  String? @db.Text

  // Relations
  events  Event[]
  pitches Pitch[]
  slots   BookableSlot[]

  @@map("categories")
}

model Event {
  eventId            String    @id @default(uuid()) @map("event_id") @db.Uuid
  eventName          String    @map("event_name") @db.VarChar(100)
  eventDatetime      DateTime  @map("event_datetime") @db.Timestamptz(6)
  eventEndtime       DateTime  @map("event_endtime") @db.Timestamptz(6)
  eventLocation      String?   @map("event_location") @db.VarChar(255)
  addressLabel       String?   @map("address_label") @db.VarChar(255)
  latitude           Float?
  longitude          Float?
  description        String?   @db.Text
  pictureUrl         String?   @map("picture_url") @db.VarChar(255)
  capacity           Int?
  priceField         Int?      @map("price_field")
  seriesId           String?   @map("series_id") @db.Uuid
  isRecurring        Boolean   @default(false) @map("is_recurring")
  recurrenceKind     String?   @map("recurrence_kind") @db.VarChar(20)
  recurrenceInterval Int?      @map("recurrence_interval")
  recurrenceWeekdays String?   @map("recurrence_weekdays") @db.VarChar(32)
  recurrenceUntil    DateTime? @map("recurrence_until") @db.Timestamptz(6)
  occurrenceIndex    Int?      @map("occurrence_index")
  isSeriesMaster     Boolean   @default(false) @map("is_series_master")
  userId             String    @map("user_id") @db.Uuid
  categoryId         String    @map("category_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  category             Category              @relation(fields: [categoryId], references: [categoryId])
  attendees            EventAttendee[]
  invitations          Invitation[]
  payments             Payment[]
  eventCreationPayment EventCreationPayment?
  savedEvents          SavedEvent[]
  waitlist             EventWaitlist[]
  refunds              Refund[]
  ticketScans          TicketScan[]

  @@index([eventDatetime])
  @@index([eventDatetime, categoryId])
  @@index([seriesId])
  @@index([userId])
  @@index([userId, eventDatetime])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("events")
}

model EventAttendee {
  attendeeId      String          @id @default(uuid()) @map("attendee_id") @db.Uuid
  eventId         String          @map("event_id") @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  purchaserUserId String          @map("purchaser_user_id") @db.Uuid
  paymentId       String?         @map("payment_id") @db.Uuid
  status          AttendeeStatus?
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  event      Event       @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  payment    Payment?    @relation(fields: [paymentId], references: [paymentId], onDelete: SetNull)
  ticketScan TicketScan?

  @@index([eventId, userId])
  @@index([eventId, purchaserUserId])
  @@index([paymentId])
  @@index([userId])
  @@map("eventattendees")
}

model Invitation {
  invitationId String           @id @default(uuid()) @map("invitation_id") @db.Uuid
  eventId      String           @map("event_id") @db.Uuid
  userId       String           @map("user_id") @db.Uuid
  expiresAt    DateTime         @map("expires_at") @db.Timestamptz(6)
  tokenHash    String           @unique @map("token_hash") @db.VarChar(64)
  maxClaims    Int              @default(0) @map("max_claims")
  claimedCount Int              @default(0) @map("claimed_count")
  status       InvitationStatus
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  event  Event             @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  claims InvitationClaim[]

  @@index([eventId, userId, status])
  @@map("invitations")
}

model InvitationClaim {
  invitationClaimId String   @id @default(uuid()) @map("invitation_claim_id") @db.Uuid
  invitationId      String   @map("invitation_id") @db.Uuid
  claimedByUserId   String   @map("claimed_by_user_id") @db.Uuid
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  invitation Invitation @relation(fields: [invitationId], references: [invitationId], onDelete: Cascade)

  @@unique([invitationId, claimedByUserId])
  @@map("invitation_claims")
}

model Payment {
  paymentId            String          @id @default(uuid()) @map("payment_id") @db.Uuid
  eventId              String          @map("event_id") @db.Uuid
  userId               String          @map("user_id") @db.Uuid
  amountEtb            Decimal         @map("amount_etb") @db.Decimal(10, 2)
  unitPriceEtb         Decimal         @default(0) @map("unit_price_etb") @db.Decimal(10, 2)
  surchargeEtb         Decimal         @default(0) @map("surcharge_etb") @db.Decimal(10, 2)
  ownerRevenueEtb      Decimal         @default(0) @map("owner_revenue_etb") @db.Decimal(10, 2)
  quantity             Int             @default(1)
  chapaSubaccountId    String?         @map("chapa_subaccount_id") @db.VarChar(64)
  currency             String          @default("ETB") @db.VarChar(10)
  provider             PaymentProvider @default(chapa)
  status               PaymentStatus   @default(created)
  providerReference    String?         @map("telebirr_prepay_id") @db.VarChar(128)
  checkoutUrl          String?         @map("telebirr_checkout_url") @db.VarChar(512)
  reservationExpiresAt DateTime?       @map("reservation_expires_at") @db.Timestamptz(6)
  verifiedAt           DateTime?       @map("verified_at") @db.Timestamptz(6)
  fulfilledAt          DateTime?       @map("fulfilled_at") @db.Timestamptz(6)
  failureReason        String?         @map("failure_reason") @db.VarChar(255)
  createdAt            DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt            DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  event     Event           @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  attendees EventAttendee[]
  refunds   Refund[]

  @@unique([provider, providerReference])
  @@index([eventId, userId])
  @@index([status])
  @@index([eventId, status, reservationExpiresAt])
  @@index([provider, status, reservationExpiresAt])
  @@map("payments")
}

model PitchOwnerProfile {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @map("user_id") @db.Uuid
  businessName          String?   @map("business_name") @db.VarChar(255)
  accountNameEnc        String?   @map("account_name_enc") @db.Text
  accountNumberEnc      String?   @map("account_number_enc") @db.Text
  bankCodeEnc           String?   @map("bank_code_enc") @db.Text
  chapaSubaccountId     String?   @unique @map("chapa_subaccount_id") @db.VarChar(64)
  splitType             String?   @map("split_type") @db.VarChar(20)
  splitValue            Decimal?  @map("split_value") @db.Decimal(10, 4)
  payoutSetupVerifiedAt DateTime? @map("payout_setup_verified_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  facilitators          Facilitator[]
  eventCreationPayments EventCreationPayment[]

  @@map("pitch_owner_profiles")
}

model Pitch {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @map("owner_id") @db.Uuid
  name         String   @db.VarChar(120)
  description  String?  @db.Text
  addressLabel String?  @map("address_label") @db.VarChar(255)
  latitude     Float?
  longitude    Float?
  categoryId   String   @map("category_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  category      Category            @relation(fields: [categoryId], references: [categoryId], onDelete: Restrict, onUpdate: Cascade)
  schedules     PitchSchedule[]
  slots         BookableSlot[]
  subscriptions PitchSubscription[]
  activityLogs  HostActivityLog[]

  @@index([ownerId, isActive])
  @@index([categoryId])
  @@map("pitches")
}

model PitchSchedule {
  id        String   @id @default(uuid()) @db.Uuid
  pitchId   String   @map("pitch_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week")
  startTime String   @map("start_time") @db.VarChar(5)
  endTime   String   @map("end_time") @db.VarChar(5)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pitch Pitch @relation(fields: [pitchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([pitchId, dayOfWeek, isActive])
  @@map("pitch_schedules")
}

model BookableSlot {
  id            String      @id @default(uuid()) @db.Uuid
  pitchId       String      @map("pitch_id") @db.Uuid
  categoryId    String      @map("category_id") @db.Uuid
  startsAt      DateTime    @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime    @map("ends_at") @db.Timestamptz(6)
  capacity      Int
  price         Decimal     @db.Decimal(10, 2)
  currency      String      @default("ETB") @db.VarChar(10)
  productType   ProductType @map("product_type")
  status        SlotStatus  @default(OPEN)
  requiresParty Boolean     @default(false) @map("requires_party")
  notes         String?     @db.Text
  createdById   String      @map("created_by_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pitch    Pitch     @relation(fields: [pitchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  category Category  @relation(fields: [categoryId], references: [categoryId], onDelete: Restrict, onUpdate: Cascade)
  bookings Booking[]

  @@index([pitchId, startsAt, endsAt])
  @@index([status, startsAt])
  @@index([categoryId])
  @@map("bookable_slots")
}

model Booking {
  id                 String           @id @default(uuid()) @db.Uuid
  slotId             String           @map("slot_id") @db.Uuid
  userId             String?          @map("user_id") @db.Uuid
  partyId            String?          @map("party_id") @db.Uuid
  productType        ProductType      @map("product_type")
  quantity           Int              @default(1)
  totalAmount        Decimal          @map("total_amount") @db.Decimal(10, 2)
  surchargeAmount    Decimal          @default(0) @map("surcharge_amount") @db.Decimal(10, 2)
  ownerRevenueAmount Decimal          @default(0) @map("owner_revenue_amount") @db.Decimal(10, 2)
  currency           String           @default("ETB") @db.VarChar(10)
  paymentProvider    PaymentProvider? @map("payment_provider")
  providerReference  String?          @unique @map("provider_reference") @db.VarChar(128)
  status             BookingStatus    @default(PENDING)
  expiresAt          DateTime?        @map("expires_at") @db.Timestamptz(6)
  paidAt             DateTime?        @map("paid_at") @db.Timestamptz(6)
  failureReason      String?          @map("failure_reason") @db.VarChar(255)
  createdAt          DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  slot        BookableSlot    @relation(fields: [slotId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  party       Party?          @relation(fields: [partyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tickets     BookingTicket[]
  paymentPool PaymentPool?

  @@index([slotId, status])
  @@index([partyId])
  @@index([userId, createdAt])
  @@map("bookings")
}

model Party {
  id        String      @id @default(uuid()) @db.Uuid
  ownerId   String      @map("owner_id") @db.Uuid
  name      String?     @db.VarChar(120)
  status    PartyStatus @default(FORMING)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  members  PartyMember[]
  bookings Booking[]
  pools    PaymentPool[]
  passes   UserPass[]

  @@index([ownerId, status])
  @@map("parties")
}

model PartyMember {
  id           String            @id @default(uuid()) @db.Uuid
  partyId      String            @map("party_id") @db.Uuid
  userId       String?           @map("user_id") @db.Uuid
  invitedEmail String?           @map("invited_email") @db.VarChar(255)
  status       PartyMemberStatus @default(INVITED)
  joinedAt     DateTime?         @map("joined_at") @db.Timestamptz(6)
  paidAt       DateTime?         @map("paid_at") @db.Timestamptz(6)
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  party         Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contributions PaymentContribution[]

  @@index([partyId, status])
  @@index([userId])
  @@map("party_members")
}

model PitchSubscription {
  id          String                  @id @default(uuid()) @db.Uuid
  ownerId     String                  @map("owner_id") @db.Uuid
  pitchId     String?                 @map("pitch_id") @db.Uuid
  status      OwnerSubscriptionStatus @default(TRIAL)
  startsAt    DateTime                @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime                @map("ends_at") @db.Timestamptz(6)
  renewalAt   DateTime?               @map("renewal_at") @db.Timestamptz(6)
  providerRef String?                 @map("provider_ref") @db.VarChar(128)
  planCode    String                  @map("plan_code") @db.VarChar(64)
  createdAt   DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pitch Pitch? @relation(fields: [pitchId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([ownerId, status, endsAt])
  @@index([pitchId])
  @@map("pitch_subscriptions")
}

model PaymentPool {
  id          String            @id @default(uuid()) @db.Uuid
  partyId     String            @map("party_id") @db.Uuid
  bookingId   String            @unique @map("booking_id") @db.Uuid
  totalAmount Decimal           @map("total_amount") @db.Decimal(10, 2)
  amountPaid  Decimal           @default(0) @map("amount_paid") @db.Decimal(10, 2)
  currency    String            @default("ETB") @db.VarChar(10)
  expiresAt   DateTime          @map("expires_at") @db.Timestamptz(6)
  status      PaymentPoolStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  party         Party                 @relation(fields: [partyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  booking       Booking               @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contributions PaymentContribution[]

  @@index([partyId, status])
  @@index([status, expiresAt])
  @@map("payment_pools")
}

model PaymentContribution {
  id             String             @id @default(uuid()) @db.Uuid
  poolId         String             @map("pool_id") @db.Uuid
  userId         String?            @map("user_id") @db.Uuid
  partyMemberId  String?            @map("party_member_id") @db.Uuid
  expectedAmount Decimal            @map("expected_amount") @db.Decimal(10, 2)
  paidAmount     Decimal            @default(0) @map("paid_amount") @db.Decimal(10, 2)
  status         ContributionStatus @default(PENDING)
  providerRef    String?            @unique @map("provider_ref") @db.VarChar(128)
  paidAt         DateTime?          @map("paid_at") @db.Timestamptz(6)
  createdAt      DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pool        PaymentPool  @relation(fields: [poolId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  partyMember PartyMember? @relation(fields: [partyMemberId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([poolId, status])
  @@index([userId])
  @@index([partyMemberId])
  @@map("payment_contributions")
}

model BookingTicket {
  id             String       @id @default(uuid()) @db.Uuid
  bookingId      String       @map("booking_id") @db.Uuid
  purchaserId    String       @map("purchaser_id") @db.Uuid
  assignedUserId String?      @map("assigned_user_id") @db.Uuid
  assignedName   String?      @map("assigned_name") @db.VarChar(120)
  assignedEmail  String?      @map("assigned_email") @db.VarChar(255)
  status         TicketStatus @default(ASSIGNMENT_PENDING)
  checkedInAt    DateTime?    @map("checked_in_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([bookingId, status])
  @@index([assignedUserId])
  @@index([purchaserId])
  @@map("booking_tickets")
}

model UserPass {
  id          String        @id @default(uuid()) @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  partyId     String?       @map("party_id") @db.Uuid
  productType ProductType   @map("product_type")
  startsAt    DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt      DateTime      @map("ends_at") @db.Timestamptz(6)
  status      BookingStatus
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  party Party? @relation(fields: [partyId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([userId, status])
  @@index([partyId])
  @@map("user_passes")
}

model HostActivityLog {
  id           String   @id @default(uuid()) @db.Uuid
  ownerId      String   @map("owner_id") @db.Uuid
  pitchId      String?  @map("pitch_id") @db.Uuid
  entityType   String   @map("entity_type") @db.VarChar(40)
  entityId     String   @map("entity_id") @db.VarChar(64)
  action       String   @db.VarChar(64)
  metadataJson Json?    @map("metadata_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  pitch Pitch? @relation(fields: [pitchId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([ownerId, createdAt])
  @@index([pitchId, createdAt])
  @@index([entityType, entityId])
  @@map("host_activity_logs")
}

model PitchOwnerPayout {
  id                      String       @id @default(uuid()) @db.Uuid
  ownerId                 String       @map("owner_id") @db.Uuid
  amountEtb               Decimal      @map("amount_etb") @db.Decimal(10, 2)
  currency                String       @default("ETB") @db.VarChar(10)
  reference               String       @unique @db.VarChar(128)
  providerTransferId      String?      @map("provider_transfer_id") @db.VarChar(128)
  status                  PayoutStatus @default(PENDING)
  destinationBusinessName String?      @map("destination_business_name") @db.VarChar(255)
  destinationAccountLast4 String?      @map("destination_account_last4") @db.VarChar(4)
  destinationBankCode     String?      @map("destination_bank_code") @db.VarChar(32)
  callbackPayloadJson     Json?        @map("callback_payload_json")
  failureReason           String?      @map("failure_reason") @db.VarChar(255)
  initiatedByUserId       String?      @map("initiated_by_user_id") @db.Uuid
  paidAt                  DateTime?    @map("paid_at") @db.Timestamptz(6)
  createdAt               DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ownerId, status, createdAt])
  @@map("pitch_owner_payouts")
}

model Facilitator {
  id                String   @id @default(uuid()) @db.Uuid
  facilitatorUserId String   @unique @map("facilitator_user_id") @db.Uuid
  pitchOwnerUserId  String   @map("pitch_owner_user_id") @db.Uuid
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  pitchOwnerProfile PitchOwnerProfile @relation(fields: [pitchOwnerUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)

  @@index([pitchOwnerUserId])
  @@map("facilitators")
}

model PromoCode {
  id               String   @id @default(uuid()) @db.Uuid
  code             String   @unique @db.VarChar(32)
  discountType     String   @map("discount_type") @db.VarChar(20)
  discountValue    Decimal  @map("discount_value") @db.Decimal(10, 4)
  pitchOwnerUserId String?  @map("pitch_owner_user_id") @db.Uuid
  maxUses          Int?     @map("max_uses")
  usedCount        Int      @default(0) @map("used_count")
  expiresAt        DateTime @map("expires_at") @db.Timestamptz(6)
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  eventCreationPayments EventCreationPayment[]

  @@index([code, isActive, expiresAt])
  @@index([pitchOwnerUserId])
  @@map("promo_codes")
}

model EventCreationFeeConfig {
  id            String    @id @default(uuid()) @db.Uuid
  amountEtb     Decimal   @map("amount_etb") @db.Decimal(10, 2)
  effectiveFrom DateTime  @map("effective_from") @db.Timestamptz(6)
  effectiveTo   DateTime? @map("effective_to") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("event_creation_fee_configs")
}

model EventCreationPayment {
  id                String    @id @default(uuid()) @db.Uuid
  pitchOwnerUserId  String    @map("pitch_owner_user_id") @db.Uuid
  eventId           String?   @unique @map("event_id") @db.Uuid
  amountEtb         Decimal   @map("amount_etb") @db.Decimal(10, 2)
  promoCodeId       String?   @map("promo_code_id") @db.Uuid
  status            String    @db.VarChar(20)
  providerReference String?   @map("provider_reference") @db.VarChar(128)
  paidAt            DateTime? @map("paid_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  eventPayloadJson  Json?     @map("event_payload_json")

  event             Event?            @relation(fields: [eventId], references: [eventId], onDelete: Cascade, onUpdate: Cascade)
  pitchOwnerProfile PitchOwnerProfile @relation(fields: [pitchOwnerUserId], references: [userId], onDelete: Cascade, onUpdate: Cascade)
  promoCode         PromoCode?        @relation(fields: [promoCodeId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([pitchOwnerUserId])
  @@map("event_creation_payments")
}

model SavedEvent {
  savedEventId String   @id @default(uuid()) @map("saved_event_id") @db.Uuid
  eventId      String   @map("event_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, createdAt])
  @@map("saved_events")
}

model EventWaitlist {
  waitlistId String   @id @default(uuid()) @map("waitlist_id") @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  event Event @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, createdAt])
  @@map("event_waitlist")
}

model UserBalance {
  userId     String   @id @map("user_id") @db.Uuid
  balanceEtb Decimal  @default(0) @map("balance_etb") @db.Decimal(10, 2)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("user_balances")
}

model Refund {
  refundId    String   @id @default(uuid()) @map("refund_id") @db.Uuid
  eventId     String   @map("event_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  paymentId   String?  @map("payment_id") @db.Uuid
  amountEtb   Decimal  @map("amount_etb") @db.Decimal(10, 2)
  ticketCount Int      @map("ticket_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  event   Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [paymentId], onDelete: SetNull)

  @@index([eventId, userId])
  @@index([paymentId])
  @@map("refunds")
}

model TicketScan {
  scanId          String   @id @default(uuid()) @map("scan_id") @db.Uuid
  attendeeId      String   @unique @map("attendee_id") @db.Uuid
  eventId         String   @map("event_id") @db.Uuid
  scannedByUserId String   @map("scanned_by_user_id") @db.Uuid
  scannedAt       DateTime @default(now()) @map("scanned_at") @db.Timestamptz(6)

  // Relations
  attendee EventAttendee @relation(fields: [attendeeId], references: [attendeeId], onDelete: Cascade)
  event    Event         @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([attendeeId])
  @@index([eventId, scannedAt])
  @@map("ticket_scan")
}

model ReminderLog {
  reminderLogId String   @id @default(uuid()) @map("reminder_log_id") @db.Uuid
  eventId       String   @map("event_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  reminderType  String   @map("reminder_type") @db.VarChar(20)
  sentAt        DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  @@unique([eventId, userId, reminderType], map: "reminder_log_event_user_type_key")
  @@map("reminder_log")
}
