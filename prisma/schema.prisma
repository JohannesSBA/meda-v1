// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}



// Prisma Schema for Event Manager Database
// This schema matches the existing PostgreSQL database structure defined in db/init/02_event_manager_db_schema.sql

// Enums
enum AttendeeStatus {
  RSVPed
  Maybe
  NotGoing

  @@map("attendee_status")
}

enum InvitationStatus {
  Active
  Expired
  Revoked

  @@map("invitation_status")
}

enum PaymentStatus {
  created
  processing
  succeeded
  failed
  canceled
  requires_refund

  @@map("payment_status")
}

enum PaymentProvider {
  balance
  chapa

  @@map("payment_provider")
}

model Category {
  categoryId    String   @id @default(uuid()) @db.Uuid @map("category_id")
  categoryName  String   @db.VarChar(50) @map("category_name")
  description   String?  @db.Text

  // Relations
  events        Event[]

  @@map("categories")
}

model Event {
  eventId       String   @id @default(uuid()) @db.Uuid @map("event_id")
  eventName     String   @db.VarChar(100) @map("event_name")
  eventDatetime DateTime @map("event_datetime") @db.Timestamptz(6)
  eventEndtime  DateTime @map("event_endtime") @db.Timestamptz(6)
  eventLocation String?   @db.VarChar(255) @map("event_location")
  addressLabel  String?   @db.VarChar(255) @map("address_label")
  latitude      Float?
  longitude     Float?
  description   String?   @db.Text
  pictureUrl    String?   @db.VarChar(255) @map("picture_url")
  capacity      Int?
  priceField    Int?      @map("price_field")
  seriesId      String?   @db.Uuid @map("series_id")
  isRecurring   Boolean   @default(false) @map("is_recurring")
  recurrenceKind String?  @db.VarChar(20) @map("recurrence_kind")
  recurrenceInterval Int? @map("recurrence_interval")
  recurrenceWeekdays String? @db.VarChar(32) @map("recurrence_weekdays")
  recurrenceUntil DateTime? @db.Timestamptz(6) @map("recurrence_until")
  occurrenceIndex Int?    @map("occurrence_index")
  isSeriesMaster Boolean  @default(false) @map("is_series_master")
  userId        String   @map("user_id") @db.Uuid
  categoryId    String   @map("category_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  category      Category          @relation(fields: [categoryId], references: [categoryId])
  attendees     EventAttendee[]
  invitations   Invitation[]
  payments      Payment[]
  savedEvents   SavedEvent[]
  waitlist      EventWaitlist[]
  refunds       Refund[]
  ticketScans   TicketScan[]

  @@index([eventDatetime])
  @@index([eventDatetime, categoryId])
  @@index([seriesId])
  @@index([userId])
  @@index([userId, eventDatetime])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@map("events")
}

model EventAttendee {
  attendeeId    String         @id @default(uuid()) @db.Uuid @map("attendee_id")
  eventId       String         @map("event_id") @db.Uuid
  userId        String         @map("user_id") @db.Uuid
  status        AttendeeStatus?
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  event         Event          @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  ticketScan    TicketScan?

  @@index([eventId, userId])
  @@index([userId])
  @@map("eventattendees")
}

model Invitation {
  invitationId  String           @id @default(uuid()) @db.Uuid @map("invitation_id")
  eventId       String           @map("event_id") @db.Uuid
  userId        String           @map("user_id") @db.Uuid
  expiresAt     DateTime         @map("expires_at") @db.Timestamptz(6)
  tokenHash     String           @unique @db.VarChar(64) @map("token_hash")
  maxClaims     Int              @default(0) @map("max_claims")
  claimedCount  Int              @default(0) @map("claimed_count")
  status        InvitationStatus
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  event         Event           @relation(fields: [eventId], references: [eventId], onDelete: Cascade)
  claims        InvitationClaim[]

  @@index([eventId, userId, status])
  @@map("invitations")
}

model InvitationClaim {
  invitationClaimId String     @id @default(uuid()) @db.Uuid @map("invitation_claim_id")
  invitationId      String     @map("invitation_id") @db.Uuid
  claimedByUserId   String     @map("claimed_by_user_id") @db.Uuid
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  invitation        Invitation @relation(fields: [invitationId], references: [invitationId], onDelete: Cascade)

  @@unique([invitationId, claimedByUserId])
  @@map("invitation_claims")
}

model Payment {
  paymentId           String        @id @default(uuid()) @db.Uuid @map("payment_id")
  eventId             String       @map("event_id") @db.Uuid
  userId              String       @map("user_id") @db.Uuid
  amountEtb           Decimal      @db.Decimal(10, 2) @map("amount_etb")
  unitPriceEtb        Decimal      @default(0) @db.Decimal(10, 2) @map("unit_price_etb")
  quantity            Int          @default(1)
  currency            String        @default("ETB") @db.VarChar(10)
  provider            PaymentProvider @default(chapa)
  status              PaymentStatus @default(created)
  providerReference   String?       @db.VarChar(128) @map("telebirr_prepay_id")
  checkoutUrl         String?       @db.VarChar(512) @map("telebirr_checkout_url")
  reservationExpiresAt DateTime?    @db.Timestamptz(6) @map("reservation_expires_at")
  verifiedAt          DateTime?     @db.Timestamptz(6) @map("verified_at")
  fulfilledAt         DateTime?     @db.Timestamptz(6) @map("fulfilled_at")
  failureReason       String?       @db.VarChar(255) @map("failure_reason")
  createdAt           DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt           DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  // Relations
  event               Event         @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([eventId, userId])
  @@index([status])
  @@index([eventId, status, reservationExpiresAt])
  @@index([provider, status, reservationExpiresAt])
  @@unique([provider, providerReference])
  @@map("payments")
}

model SavedEvent {
  savedEventId String   @id @default(uuid()) @db.Uuid @map("saved_event_id")
  eventId      String   @map("event_id") @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relations
  event        Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([userId, createdAt])
  @@map("saved_events")
}

model EventWaitlist {
  waitlistId String   @id @default(uuid()) @db.Uuid @map("waitlist_id")
  eventId    String   @map("event_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  event      Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId, createdAt])
  @@map("event_waitlist")
}

model UserBalance {
  userId     String   @id @db.Uuid @map("user_id")
  balanceEtb Decimal  @default(0) @db.Decimal(10, 2) @map("balance_etb")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("user_balances")
}

model Refund {
  refundId    String   @id @default(uuid()) @db.Uuid @map("refund_id")
  eventId     String   @map("event_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  amountEtb   Decimal  @db.Decimal(10, 2) @map("amount_etb")
  ticketCount Int      @map("ticket_count")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  // Relations
  event       Event    @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([eventId, userId])
  @@map("refunds")
}

model TicketScan {
  scanId          String        @id @default(uuid()) @db.Uuid @map("scan_id")
  attendeeId      String        @unique @map("attendee_id") @db.Uuid
  eventId         String        @map("event_id") @db.Uuid
  scannedByUserId String        @map("scanned_by_user_id") @db.Uuid
  scannedAt       DateTime      @default(now()) @map("scanned_at") @db.Timestamptz(6)

  // Relations
  attendee        EventAttendee @relation(fields: [attendeeId], references: [attendeeId], onDelete: Cascade)
  event           Event         @relation(fields: [eventId], references: [eventId], onDelete: Cascade)

  @@index([attendeeId])
  @@index([eventId, scannedAt])
  @@map("ticket_scan")
}
